(function initSha256Cipher(global) {
  const root = global.KryptoCiphers || (global.KryptoCiphers = {});

  // K-Konstanten pre-computed – keine Recompute pro Hash
  const K = new Uint32Array([
    0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
    0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
    0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
    0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
    0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
    0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
    0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
    0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
  ]);

  function encodeUtf8(text) {
    const source = String(text || "");
    if (typeof TextEncoder !== "undefined") {
      return new TextEncoder().encode(source);
    }
    if (typeof Buffer !== "undefined") {
      return Uint8Array.from(Buffer.from(source, "utf8"));
    }
    // Fallback: UTF-8 durch encodeURIComponent
    const encoded = unescape(encodeURIComponent(source));
    const bytes = new Uint8Array(encoded.length);
    for (let i = 0; i < encoded.length; i += 1) {
      bytes[i] = encoded.charCodeAt(i);
    }
    return bytes;
  }

  function rightRotate(v, n) {
    // 32-bit: >>> 0 hält Bitops konsistent in JS
    return ((v >>> n) | (v << (32 - n))) >>> 0;
  }

  function bytesToHex(bytes) {
    let hex = "";
    for (const b of bytes) {
      hex += ("0" + b.toString(16).toUpperCase()).slice(-2);
    }
    return hex;
  }

  function sha256(text) {
    const bytes = encodeUtf8(text);
    let h0 = 0x6a09e667, h1 = 0xbb67ae85, h2 = 0x3c6ef372, h3 = 0xa54ff53a;
    let h4 = 0x510e527f, h5 = 0x9b05688c, h6 = 0x1f83d9ab, h7 = 0x5be0cd19;

    // Message-Padding: 1-bit + zeros + 64-bit length
    const msgLen = bytes.length;
    const blockLen = 64;
    const paddedLen = Math.ceil((msgLen + 9) / blockLen) * blockLen;
    const padded = new Uint8Array(paddedLen);
    padded.set(bytes);
    padded[msgLen] = 0x80;

    // 64-bit length (Big-Endian) am Ende
    const bits = msgLen * 8;
    for (let i = 0; i < 8; i += 1) {
      padded[paddedLen - 8 + i] = (bits >>> (56 - i * 8)) & 0xff;
    }

    // 512-bit Blöcke verarbeiten
    for (let offset = 0; offset < paddedLen; offset += blockLen) {
      const w = new Uint32Array(64);
      // W[0..15]: Read Block Big-Endian
      for (let i = 0; i < 16; i += 1) {
        const idx = offset + i * 4;
        w[i] = ((padded[idx] << 24) | (padded[idx+1] << 16) | (padded[idx+2] << 8) | padded[idx+3]) >>> 0;
      }
      // W[16..63]: Aus vorherigen berechnet (Kryptosicherheit)
      for (let i = 16; i < 64; i += 1) {
        const s0 = (rightRotate(w[i-15], 7) ^ rightRotate(w[i-15], 18) ^ (w[i-15] >>> 3)) >>> 0;
        const s1 = (rightRotate(w[i-2], 17) ^ rightRotate(w[i-2], 19) ^ (w[i-2] >>> 10)) >>> 0;
        w[i] = (w[i-16] + s0 + w[i-7] + s1) >>> 0;
      }

      let a = h0, b = h1, c = h2, d = h3, e = h4, f = h5, g = h6, h = h7;
      for (let i = 0; i < 64; i += 1) {
        const S1 = (rightRotate(e, 6) ^ rightRotate(e, 11) ^ rightRotate(e, 25)) >>> 0;
        const ch = ((e & f) ^ ((~e) & g)) >>> 0;
        const t1 = (h + S1 + ch + K[i] + w[i]) >>> 0;
        const S0 = (rightRotate(a, 2) ^ rightRotate(a, 13) ^ rightRotate(a, 22)) >>> 0;
        const maj = ((a & b) ^ (a & c) ^ (b & c)) >>> 0;
        const t2 = (S0 + maj) >>> 0;
        h = g; g = f; f = e; e = (d + t1) >>> 0;
        d = c; c = b; b = a; a = (t1 + t2) >>> 0;
      }

      h0 = (h0 + a) >>> 0; h1 = (h1 + b) >>> 0; h2 = (h2 + c) >>> 0; h3 = (h3 + d) >>> 0;
      h4 = (h4 + e) >>> 0; h5 = (h5 + f) >>> 0; h6 = (h6 + g) >>> 0; h7 = (h7 + h) >>> 0;
    }

    // H0..H7 zu 32 Bytes Big-Endian
    const digest = new Uint8Array(32);
    const hashes = [h0, h1, h2, h3, h4, h5, h6, h7];
    for (let i = 0; i < 8; i += 1) {
      digest[i*4] = (hashes[i] >>> 24) & 0xff;
      digest[i*4+1] = (hashes[i] >>> 16) & 0xff;
      digest[i*4+2] = (hashes[i] >>> 8) & 0xff;
      digest[i*4+3] = hashes[i] & 0xff;
    }
    return bytesToHex(digest);
  }

  function isValidSha256Hash(text) {
    const norm = String(text || "").toUpperCase().replace(/\s+/g, "");
    return /^[A-F0-9]{64}$/.test(norm);
  }

  root.sha256Cipher = {
    id: "sha-256",
    name: "SHA-256",
    supportsKey: false,
    info: {
      purpose: "Sichere kryptografische Hashfunktion mit 256-Bit-Ausgang.",
      process: "Text → 512-Bit-Blöcke → mathematische Operationen → 64-stelliger HEX-Code.",
      crack: "Einwegfunktion: Nur Kandidaten-Vergleich möglich.",
      useCase: "Blockchain, digitale Signaturen, Passwort-Hashing.",
      note: "Entschlüsselung ist Work in Progress (nur Kandidatenvergleich).",
    },

    encrypt(text) {
      return sha256(text);
    },

    decrypt(text) {
      // SHA-256 ist irreversibel – klarer Fehler statt verwirrtem Fallback
      throw new Error("SHA-256 ist irreversibel. Nutze 'Entschlüsseln' mit Kandidaten.");
    },

    crack(text, options) {
      if (!isValidSha256Hash(text)) {
        return {
          text: null,
          confidence: -Infinity,
          search: { wip: true, wipMessage: "SHA-256: Kein gültiger 64-Hex-Hash." },
        };
      }

      const norm = String(text || "").toUpperCase().replace(/\s+/g, "");
      const cands = Array.isArray(options && options.candidates) ? options.candidates : [];

      // Ohne Kandidaten: WIP möglich
      if (cands.length === 0) {
        return {
          text: null,
          confidence: -Infinity,
          search: { wip: true, wipMessage: "SHA-256: Entschlüsselung ist Work in Progress (nur Kandidatenvergleich)." },
        };
      }

      // Kandidaten durchsuchen
      for (const c of cands) {
        if (sha256(String(c || "")).toUpperCase() === norm) {
          return {
            text: String(c),
            confidence: 100,
            candidates: [{ text: String(c), confidence: 100 }],
          };
        }
      }

      return {
        text: null,
        confidence: -Infinity,
        search: { wip: true, wipMessage: "SHA-256: Keine Übereinstimmung in Kandidaten." },
      };
    },
  };
})(window);
